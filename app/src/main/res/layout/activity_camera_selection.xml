<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Scanner"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnScanInjury"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Scan Injury"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#FF9800" /> <Button
    android:id="@+id/btnScanMedicine"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:text="Scan Medicine"
    android:textSize="18sp"
    android:backgroundTint="#4CAF50" /> </LinearLayout>